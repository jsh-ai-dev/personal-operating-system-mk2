# PostgreSQL — 첫 번째 프로젝트와 같은 서버를 쓴다면 DB 이름만 다르게 (예: personal_os_v2)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/personal_os_v2?schema=public"

# API (Next 기본 3000과 겹치지 않게)
PORT=3001

# CORS — 프론트 출처 (쉼표로 여러 개 가능)
CORS_ORIGIN="http://localhost:3000"

# --- JWT (로그인 토큰 서명용 비밀키) ---
# JWT_SECRET 은 서버만 아는 "도장" 같은 값입니다. 이걸로 토큰을 만들고·검증합니다.
# 짧거나 추측 가능하면 누가 가짜 로그인 토큰을 만들 수 있으므로, 충분히 긴 무작위 문자열을 씁니다.
#
# 로컬에서 새 값 만들기 (복사해서 backend/.env 에 붙이기, Git 에는 올리지 마세요):
#   npm run gen:jwt-secret --prefix backend
#
# 비우면 개발 모드에서만 코드에 있는 임시 기본값이 쓰이고 경고가 납니다.
# 프로덕션(NODE_ENV=production)에서는 반드시 설정해야 합니다.
# 배포 시: 호스팅의 Environment / Secrets 에만 넣고, 저장소·채팅에 실제 값을 남기지 마세요.
JWT_SECRET=
JWT_EXPIRES_IN="7d"
