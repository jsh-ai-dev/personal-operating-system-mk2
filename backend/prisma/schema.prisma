generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  createdAt      DateTime        @default(now()) @map("created_at")
  calendarMemos  CalendarMemo[]
  monthlyGoals   MonthlyGoal[]
  weeklyGoals    WeeklyGoal[]

  @@map("users")
}

model CalendarMemo {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey   String   @map("date_key")
  brief     String   @default("")
  detail    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, dateKey])
  @@map("calendar_memos")
}

/// `toYearMonthKey`와 동일 (YYYY-MM), 사용자별 1행
model MonthlyGoal {
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearMonth String   @map("year_month")
  body      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, yearMonth])
  @@map("monthly_goals")
}

/// 달력 그리드 행 키 `YYYY-MM-DD_YYYY-MM-DD`, 사용자별 1행
model WeeklyGoal {
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rangeKey  String   @map("range_key")
  body      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, rangeKey])
  @@map("weekly_goals")
}
