generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 프론트의 날짜별 메모와 맞추기 위한 최소 스키마 (추후 확장)
model CalendarMemo {
  id        String   @id @default(uuid())
  dateKey   String   @unique @map("date_key")
  brief     String   @default("")
  detail    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("calendar_memos")
}

/// `toYearMonthKey`와 동일 (YYYY-MM)
model MonthlyGoal {
  yearMonth String   @id @map("year_month")
  body      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("monthly_goals")
}

/// 달력 그리드 행 키 `YYYY-MM-DD_YYYY-MM-DD`
model WeeklyGoal {
  rangeKey  String   @id @map("range_key")
  body      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("weekly_goals")
}
