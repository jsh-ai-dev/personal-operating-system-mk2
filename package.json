{
  "name": "personal-operating-system-mk2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:web": "next dev --webpack",
    "dev:api": "npm run start:dev --prefix backend",
    "dev:auth": "npm run start:dev --prefix auth-service",
    "dev:all": "concurrently -n web,api,auth -c auto \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:auth\"",
    "dev:turbo": "next dev --turbopack",
    "dev:split": "npm run dev:web",
    "gen:jwt-secret": "npm run gen:jwt-secret --prefix backend",
    "build": "next build",
    "build:api": "npm run build --prefix backend",
    "start": "next start",
    "start:web": "next start",
    "start:api": "npm run start --prefix backend",
    "docker:up": "docker compose up -d",
    "docker:up:split": "docker compose -f compose.yaml -f compose.apps.yaml up -d --build",
    "docker:down:split": "docker compose -f compose.yaml -f compose.apps.yaml down",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "date-holidays": "^3.26.13",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
